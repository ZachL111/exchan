{
  "repo": "exchan",
  "language": "Elixir",
  "category": "Distributed data",
  "goal": "Track CRDT-backed presence state with joins, leaves, and clock merges.",
  "weights": {
    "signal": 3,
    "slack": 2,
    "confidence": 1,
    "drag": 2
  },
  "thresholds": {
    "ship": 161,
    "watch": 108
  },
  "properties": [
    "raising signal cannot reduce score",
    "raising drag cannot improve score",
    "lane labels must match configured thresholds",
    "golden fixture ids must remain unique"
  ],
  "fixture_files": [
    "fixtures/golden/scoreboard.csv",
    "fixtures/golden/lane-matrix.csv",
    "fixtures/fuzz/mutations.csv",
    "fixtures/fuzz/boundary-cases.jsonl"
  ]
}
